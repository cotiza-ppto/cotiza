{
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "email.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "upload.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/db_config.php",  "status": 403 },
    { "src": "/settings.json",  "status": 403 },
    { "src": "/debug.txt",      "status": 403 },
    { "src": "/error_log",      "status": 403 },
    { "src": "/split_js.php",   "status": 403 },
    { "src": "/libs/(.*)",      "status": 403 },
    { "src": "/index.php",      "dest": "/index.php" },
    { "src": "/api.php",        "dest": "/api.php" },
    { "src": "/email.php",      "dest": "/email.php" },
    { "src": "/upload.php",     "dest": "/upload.php" },
    { "src": "/(.*)",           "dest": "/$1" }
  ]
}
