{
  "functions": {
    "*.php": { "runtime": "vercel-php@0.6.0" },
    "api.php": { "runtime": "vercel-php@0.6.0" }
  },
  "routes": [
    { "src": "/settings.json", "status": 403 },
    { "src": "/debug.txt", "status": 403 },
    { "src": "/error_log", "status": 403 },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
